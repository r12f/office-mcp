{
  "name": "office-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local MCP bridge for live Microsoft Office documents.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test && npm run check:cli",
    "check:cli": "tsx src/cli.ts config endpoints && tsx src/cli.ts config show && tsx src/cli.ts config claude-desktop && tsx src/cli.ts config claude-desktop --installed --install-root C:\\office-mcp-test",
    "cli": "tsx src/cli.ts",
    "daemon": "tsx src/cli.ts daemon run",
    "evidence:irm": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not $env:OFFICE_MCP_IRM_DOCUMENT_PATH) { $env:OFFICE_MCP_IRM_DOCUMENT_PATH = 'C:\\Users\\riffjiang\\Downloads\\Document 2026-05-31 (6).docx' }; & .\\node_modules\\.bin\\tsx.cmd test/runtime-evidence.ts --endpoint http://127.0.0.1:8800/mcp --output ../artifacts/runtime-evidence-irm.json --irm-mode protected-read --wait-for-session-ms 120000\"",
    "evidence:runtime": "tsx test/runtime-evidence.ts",
    "evidence:record-agent-client": "tsx test/record-agent-client-evidence.ts",
    "evidence:validate": "tsx test/validate-runtime-evidence.ts",
    "smoke:mcp": "tsx test/mcp-smoke.ts",
    "smoke:ui": "tsx test/ui-browser-smoke.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ws": "8.21.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.0.3",
    "@types/office-js": "^1.0.592",
    "@types/ws": "8.18.1",
    "tsx": "4.22.4",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}



