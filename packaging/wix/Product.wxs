<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="office-mcp"
    Manufacturer="office-mcp"
    Version="$(var.PackageVersion)"
    UpgradeCode="9A4F5F83-742B-44A7-98D7-7CCFE7CBA752"
    Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of office-mcp is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="office-mcp" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="office-mcp" Level="1">
      <ComponentGroupRef Id="OfficeMcpPayloadComponents" />
      <ComponentRef Id="OfficeMcpRegistry" />
    </Feature>
  </Package>

  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="OfficeMcpRegistry" Guid="86E90F37-0D2D-472E-8B8E-BF62399243BF">
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Office\16.0\WEF\TrustedCatalogs\office-mcp"
          Name="Id"
          Type="string"
          Value="office-mcp"
          KeyPath="yes" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Office\16.0\WEF\TrustedCatalogs\office-mcp"
          Name="Url"
          Type="string"
          Value="[INSTALLFOLDER]addin-catalog" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Office\16.0\WEF\TrustedCatalogs\office-mcp"
          Name="Flags"
          Type="integer"
          Value="1" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="office-mcp"
          Type="string"
          Value="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]office-mcp-tray.ps1&quot;" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
