<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="office-mcp"
    Manufacturer="office-mcp"
    Version="$(var.PackageVersion)"
    UpgradeCode="9A4F5F83-742B-44A7-98D7-7CCFE7CBA752"
    Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of office-mcp is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="office-mcp" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="office-mcp" Level="1">
      <ComponentGroupRef Id="OfficeMcpPayloadComponents" />
      <ComponentRef Id="OfficeMcpRegistry" />
    </Feature>

    <CustomAction
      Id="ConfigureOfficeMcpUserState"
      Directory="INSTALLFOLDER"
      Execute="deferred"
      Impersonate="yes"
      ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]office-mcp-install-user.ps1&quot;" />

    <InstallExecuteSequence>
      <Custom Action="ConfigureOfficeMcpUserState" After="InstallFiles" Condition="NOT REMOVE" />
    </InstallExecuteSequence>
  </Package>

  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="OfficeMcpRegistry" Guid="86E90F37-0D2D-472E-8B8E-BF62399243BF">
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="office-mcp"
          Type="string"
          Value="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]office-mcp-daemon.ps1&quot;"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
